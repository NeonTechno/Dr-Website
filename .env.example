# NVIDIA API Configuration
# Get your API keys from https://developer.nvidia.com

NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_VERIFICATION_API_URL=https://api.nvidia.com/verify
NVIDIA_ANALYTICS_API_URL=https://api.nvidia.com/analytics

# DRP Configuration
NEXT_PUBLIC_APP_NAME=Decentralized Rights Protocol
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_NETWORK=mainnet

# Blockchain Configuration
NEXT_PUBLIC_RPC_URL=https://mainnet.drp.io
NEXT_PUBLIC_CHAIN_ID=1

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_VERIFICATION=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NVIDIA_INTEGRATION=true